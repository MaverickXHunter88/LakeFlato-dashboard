import json
from datetime import datetime
from zoneinfo import ZoneInfo

local_tz = ZoneInfo("America/Chicago")

input_file = "data_log_2026-03-30.jsonl"
output_file = "data_log_2026-03-30.clean.jsonl"

rows = []

with open(input_file) as f:
    for line in f:
        try:
            row = json.loads(line)
        except:
            continue

        dt = None

        if "timestamp_local" in row and row["timestamp_local"]:
            dt = datetime.fromisoformat(row["timestamp_local"])
            if dt.tzinfo:
                dt = dt.astimezone(local_tz).replace(tzinfo=None)

        elif "timestamp_utc" in row and row["timestamp_utc"]:
            dt = datetime.fromisoformat(row["timestamp_utc"])
            dt = dt.astimezone(local_tz).replace(tzinfo=None)

        elif "timestamp" in row and row["timestamp"]:
            dt = datetime.fromisoformat(row["timestamp"])
            if dt.tzinfo:
                dt = dt.astimezone(local_tz).replace(tzinfo=None)

        if not dt:
            continue

        # overwrite with clean timestamp
        row["timestamp"] = dt.isoformat()

        # remove messy fields
        row.pop("timestamp_local", None)
        row.pop("timestamp_utc", None)

        rows.append(row)

rows.sort(key=lambda r: r["timestamp"])

with open(output_file, "w") as f:
    for r in rows:
        f.write(json.dumps(r) + "\n")

print("Clean file written:", output_file)
PY
